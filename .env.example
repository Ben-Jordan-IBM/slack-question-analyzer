# Everything runs on LOCAL Ollama — free, private, no transcript ever
# leaves the machine. Cloud providers are not supported by design
# (AI_PROVIDER exists in code but rejects any value other than 'ollama').

# Ollama Configuration
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text
# Chat model for the LLM features. Leave unset for auto (recommended):
# llama3.1:8b on machines with >=12GB RAM, llama3.2 (3B) on smaller ones.
# If the chosen model isn't downloaded but llama3.2 is, the app uses llama3.2.
# OLLAMA_GENERATION_MODEL=llama3.1:8b

# Similarity threshold: leave unset for 'auto' (recommended — model-aware
# default that relaxes itself when nothing groups). Setting a number pins it.
# SIMILARITY_THRESHOLD=0.85

# Near-duplicate merge threshold (token overlap, 0-1; merged without AI)
# LEXICAL_DEDUP_THRESHOLD=0.9

# Two different rewrites of one ask from the SAME message collapse to one
# question above this content-word overlap (exact repeats are never collapsed)
# SAME_MESSAGE_REPHRASE_OVERLAP=0.5

# How far above the corpus noise bulk (p90) the grouping bar sits
# NOISE_GATE_MARGIN=0.05

# A join that clears the grouping bar only narrowly while sharing almost no
# distinctive subject words with the group defers to the AI verifier instead
# of merging on template similarity (0 disables)
# MERGE_SUBJECT_MIN=0.25

# An extracted question must share at least this token support with its
# claimed source message, or it is reassigned/dropped
# EXTRACT_SUPPORT_MIN=0.35

# Broadcast announcements (webinar promos, sales-kit posts, win wires) and
# "please note" notices are treated as context, never question sources
# ('off' extracts from them too)
# ANNOUNCEMENT_FILTER=on

# Domain hint injected into every LLM prompt — set this! Knowing the product
# makes topic labels and extraction dramatically more specific.
# DOMAIN_CONTEXT=a webMethods MFT support Slack channel

# Learned topic bank: names + summaries carry across analyses ('off' disables)
# TOPIC_BANK=on
# TOPIC_BANK_PATH=topic_bank.json
# Optional seed topics file loaded into the bank on first run
# SEED_TOPICS_PATH=seed_topics.json

# Minimum similarity for the topic bank to claim a group with a known name
# BANK_MATCH_THRESHOLD=0.85

# Optional LLM features: 'auto' (when the model is available), 'on', or 'off'.
# GROUP_LABELS=off disables all of them at once.
# GROUP_LABELS=auto
# LLM_VERIFY_GROUPS=auto
# LLM_EXTRACTION=auto   # auto = LLM-first up to 150 msgs; full = always; on = regex-first
# EXTRACT_QUALITY_MAX=30  # transcripts up to this many messages use the QUALITY
#                         # model for extraction end-to-end (slower, more accurate)
# LLM_ANSWER_DETECTION=auto
# EXECUTIVE_SUMMARY=auto
# LLM_VERIFY_MARGIN=0.03
# LLM_VERIFY_MAX=10
# LLM_VERIFY_LEXICAL_MIN=0.7   # shared-subject overlap (prefix-tolerant) that
#                              # also surfaces a pair for verification (>1.0 disables)
# LLM_VERIFY_LEXICAL_MAX=5     # separate budget for those lexical candidates
# LLM_VERIFY_LEXICAL_SLACK=0.15 # numeric tightness floor for those pairs
# SHARED_SUBJECT_MIN=0.5    # same-subject overlap that downgrades the
#                           # cross-type veto to 'ask the verifier' (>1.0 disables)
# LLM_RESCUE_MARGIN=0.1     # singleton-rescue candidacy window below the bar (pairs)
# LLM_RESCUE_MARGIN_LARGE=0.05  # tighter window for rescuing into 3+ groups
# LLM_RESCUE_MAX=10         # rescue adjudication cap per run
# LLM_AUDIT_MAX=10          # audit cap per run (was silently shared with verify)
# LLM_AUDIT_NOMINEE_MAX=3   # overrule-verify fan-out cap per audited group
# LLM_FEEDBACK_MAX=15       # feature-request confirm cap (overflow stays in support)
# LLM_CONSOLIDATE_CONFIRM_MAX=3  # same-ask confirm fan-out cap per message
# LLM_RESCUE_MAX_GROUP=4    # rescue may complete groups up to this size
# LLM_CONSOLIDATE_MAX=15    # same-ask consolidation call cap per run
# FAQ_DRAFT_ANSWERS=auto  # condense confirmed thread replies into draft FAQ
#                         # answers (grounded: facts must come from the replies)
# FAQ_DRAFT_MAX=10        # draft cap per analysis
# THEMES=auto   # LLM theme fallback when no taxonomy.json is present

# Routing taxonomy (the category funnel). Buckets live in taxonomy.json —
# edit them freely and bump its 'version'. TAXONOMY=off disables routing.
# Questions are grouped GLOBALLY by meaning first; each resulting cluster
# then routes to a bucket by its representative.
# TAXONOMY=on
# TAXONOMY_PATH=taxonomy.json
# IN_BUCKET_THRESHOLD=0.8       # fixed global grouping bar
# ROUTE_OUTLIER_FLOOR=0.4       # below this to every anchor -> needs review
# ROUTE_CONFIDENCE_FLOOR=0.55   # weak best anchor -> LLM decides (may abstain)
# ROUTE_AMBIGUITY_MARGIN=0.05   # top-2 anchors closer than this -> LLM decides
# ROUTE_LLM_MAX=40              # cap on LLM adjudication calls per run
# ROUTE_MEMBER_COHERENCE=on     # members voting against their cluster's route
#                               # demote it to LLM choice / review

# Per-call LLM timeout in seconds (8B models on CPU can be slow)
# LLM_TIMEOUT=180

# Model for token-heavy work (question extraction/detection). Defaults to
# llama3.2 when the main chat model is bigger and llama3.2 is downloaded,
# so big models do the judging and the small one does the typing.
# OLLAMA_FAST_MODEL=llama3.2

# Above this many questions, clustering switches to the memory-lean path
# LARGE_CLUSTERING_THRESHOLD=2000

# Round-trip embedding probe before each run ('off' skips it)
# EMBEDDING_PREFLIGHT=on

# Caches (on by default): embeddings + deterministic LLM outputs
# EMBEDDING_CACHE=on
# EMBEDDING_CACHE_DIR=.embedding_cache
# EMBEDDING_CACHE_MAX=20000   # oldest entries evicted beyond this
# LLM_CACHE=on
# LLM_CACHE_DIR=.llm_cache
# LLM_CACHE_MAX=5000

# Saved-analysis history cap (0 = keep everything)
# MAX_SAVED_ANALYSES=200

# API server
# API_HOST=127.0.0.1
# API_PORT=5000
# FLASK_DEBUG=0
# MAX_CONTENT_MB=50
# ANALYSES_DIR=analyses
# JOBS_DIR=jobs                # background-job state files
# MAX_CONCURRENT_JOBS=1        # analyses run one at a time by default
# NO_BROWSER=1                 # set to stop the server auto-opening the dashboard
